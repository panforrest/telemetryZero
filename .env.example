# telemetryZero — example env. Copy to .env.local and fill in your keys.
# .env.local is gitignored so your keys never get committed.

# OpenAI: powers the live multi-agent run + LLM-as-judge eval scores
OPENAI_API_KEY=sk-...

# Tavily (sponsor): the agent's web-search tool. Free key: https://app.tavily.com
TAVILY_API_KEY=tvly-...

# Optional: model override for the agent runtime
OPENAI_MODEL=gpt-4o-mini
